# Network Monitor Configuration

# Database
DATABASE_URL=sqlite+aiosqlite:///./network_monitor.db

# Telegram (optional - leave empty to disable)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_CA_BUNDLE=

# Monitoring Settings
CHECK_INTERVAL=30
FAIL_THRESHOLD=3
TIMEOUT=2

# JWT / sessions
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRATION=86400
SESSION_HTTPS_ONLY=false

# Application
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false
LOG_LEVEL=INFO
APP_TIMEZONE=

# Reverse proxy / Linux deployment
UVICORN_FORWARDED_ALLOW_IPS=127.0.0.1

# Production hardening
# For direct first launch over LAN/IP you can temporarily use TRUSTED_HOSTS=*
# or include the final server IP / DNS name in the list below.
TRUSTED_HOSTS=localhost,127.0.0.1
FORCE_HTTPS=false

# First admin bootstrap
AUTO_CREATE_ADMIN=false
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=ChangeMe123!
