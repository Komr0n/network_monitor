# Reverse proxy production profile
# Use this with nginx or another reverse proxy that connects to 127.0.0.1:8000.
# Direct IP / LAN access should use deploy/linux/.env.linux.ip.example instead.

# Database
DATABASE_URL=sqlite+aiosqlite:////opt/network_monitor/network_monitor.db

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_CA_BUNDLE=

# Monitoring
CHECK_INTERVAL=30
FAIL_THRESHOLD=3
TIMEOUT=2

# Auth / session
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRATION=86400
SESSION_HTTPS_ONLY=true

# Application
APP_HOST=127.0.0.1
APP_PORT=8000
DEBUG=false
LOG_LEVEL=INFO
APP_TIMEZONE=

# Reverse proxy
UVICORN_FORWARDED_ALLOW_IPS=127.0.0.1

# Host / HTTPS hardening
TRUSTED_HOSTS=monitor.example.com,127.0.0.1,localhost
FORCE_HTTPS=false

# First start only
AUTO_CREATE_ADMIN=true
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=ChangeMeNow123!
