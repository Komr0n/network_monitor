# Direct IP / LAN deployment without nginx
# Use this when clients connect to http://SERVER_IP:8000 directly.
# Switch to the reverse-proxy template for public HTTPS production.

# Database
DATABASE_URL=sqlite+aiosqlite:////opt/network_monitor/network_monitor.db

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_CA_BUNDLE=

# Monitoring
CHECK_INTERVAL=30
FAIL_THRESHOLD=3
TIMEOUT=2

# Auth / session
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRATION=86400
SESSION_HTTPS_ONLY=false

# Application
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false
LOG_LEVEL=INFO
APP_TIMEZONE=

# Reverse proxy
UVICORN_FORWARDED_ALLOW_IPS=127.0.0.1

# Host / HTTPS hardening
# Replace * with the final server IP or DNS name after the first successful launch if you want stricter host checks.
TRUSTED_HOSTS=*
FORCE_HTTPS=false

# First start only
AUTO_CREATE_ADMIN=true
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=ChangeMeNow123!
